# CodeEcho - Environment Variables Template
# Copy this file to .env and replace placeholder values with your actual API keys

# GitHub Personal Access Token
# Get from: https://github.com/settings/tokens
# Required scopes: repo, public_repo, read:org
GITHUB_TOKEN=your-github-token-here

# AI Provider Selection
# Options: openai, github copilot, azure
AI_PROVIDER=openai

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
# Make sure you have billing set up for API usage
OPENAI_API_KEY=your-openai-api-key-here

# Azure OpenAI (Optional - for enterprise use)
# AZURE_OPENAI_KEY=your-azure-openai-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Optional: Uncomment to change default port
# SERVER_PORT=8080
